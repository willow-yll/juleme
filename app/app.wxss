/* 全局样式 - 聚了吗小程序 */

page {
  /* 颜色变量 */
  --primary: #9B7DED;
  --secondary: #FFAB76;
  --accent: #7DD3C0;
  --bg: #F8F6FF;
  --white: #FFFFFF;
  --text: #333333;
  --text-light: #666666;
  --text-muted: #999999;
  --border: #E8E4F3;

  /* 阴影变量 */
  --shadow: 0 8rpx 24rpx rgba(155, 125, 237, 0.15);
  --shadow-sm: 0 4rpx 12rpx rgba(155, 125, 237, 0.1);
  --shadow-fab: 0 8rpx 24rpx rgba(155, 125, 237, 0.4);
  --shadow-bottom: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);

  /* 间距变量 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;

  /* 圆角变量 */
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-full: 40rpx;
  --radius-circle: 50%;

  /* 文字层级 */
  --text-title: 36rpx;
  --text-body: 28rpx;
  --text-secondary: 26rpx;
  --text-small: 24rpx;
  --text-tiny: 22rpx;

  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: var(--text-body);
  color: var(--text);
  line-height: 1.6;
}

/* 容器 */
.container {
  padding: 24rpx;
  min-height: 100vh;
}

/* 卡片 */
.card {
  background: var(--white);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow);
}

/* 按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary), #B794F6);
  color: var(--white);
}

.btn-secondary {
  background: linear-gradient(135deg, var(--secondary), #FFCBA4);
  color: var(--white);
}

.btn-accent {
  background: linear-gradient(135deg, var(--accent), #9AE3D6);
  color: var(--white);
}

.btn-outline {
  background: var(--white);
  border: 2rpx solid var(--primary);
  color: var(--primary);
}

/* 标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  background: var(--bg);
  color: var(--primary);
}

.tag-restaurant { background: #FFF3E0; color: #FF9800; }
.tag-travel { background: #E3F2FD; color: #2196F3; }
.tag-sport { background: #E8F5E9; color: #4CAF50; }
.tag-other { background: #F3E5F5; color: #9C27B0; }

/* 输入框 */
.input {
  background: var(--bg);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.input:focus {
  border-color: var(--primary);
  background: var(--white);
}

/* Flex 工具 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-center { align-items: center; justify-content: center; }
.flex-between { justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }

/* 间距 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.ml-10 { margin-left: 10rpx; }
.mr-10 { margin-right: 10rpx; }

/* 文字 */
.text-primary { color: var(--primary); }
.text-secondary { color: var(--secondary); }
.text-accent { color: var(--accent); }
.text-light { color: var(--text-light); }
.text-muted { color: var(--text-muted); }
.text-sm { font-size: 24rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-bold { font-weight: 600; }

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  object-fit: cover;
}

.avatar-sm { width: 60rpx; height: 60rpx; }
.avatar-lg { width: 120rpx; height: 120rpx; }

/* 阴影 */
.shadow { box-shadow: var(--shadow); }
.shadow-sm { box-shadow: var(--shadow-sm); }

/* 圆角 */
.rounded { border-radius: 16rpx; }
.rounded-lg { border-radius: 24rpx; }
.rounded-full { border-radius: 50%; }

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.empty-text {
  color: var(--text-muted);
  font-size: 28rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* 加载中 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 渐变背景 */
.gradient-bg {
  background: linear-gradient(135deg, var(--primary), #B794F6, var(--secondary));
}

/* 毛玻璃效果 */
.glass {
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slideUp {
  from { opacity: 0; transform: translateY(100%); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.animate-fadeIn { animation: fadeIn 0.5s ease forwards; }
.animate-slideUp { animation: slideUp 0.5s ease forwards; }
.animate-pulse { animation: pulse 2s ease infinite; }

/* ===== 统一可复用样式 ===== */

/* 卡片统一外壳 */
.card-shell {
  background: var(--white);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow);
}

/* 页内标签切换 */
.section-tabs {
  display: flex;
  gap: var(--spacing-md);
  padding: var(--spacing-lg);
}

.section-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  background: var(--white);
  border-radius: var(--radius-lg);
  color: var(--text-light);
  font-size: var(--text-secondary);
  transition: all 0.3s ease;
}

.section-tab.active {
  background: linear-gradient(135deg, var(--primary), #B794F6);
  color: var(--white);
  font-weight: 600;
}

/* 图标强制居中 */
.icon-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-center-sm {
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

/* 空状态统一 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon-center {
  font-size: 120rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.5;
  line-height: 1;
}

.empty-text-center {
  color: var(--text-muted);
  font-size: var(--text-body);
}

/* 悬浮按钮统一 */
.floating-action {
  position: fixed;
  bottom: 160rpx;
  right: var(--spacing-lg);
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-circle);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: transform 0.3s ease;
}

.floating-action:active {
  transform: scale(0.95);
}

.fab-primary {
  background: linear-gradient(135deg, var(--primary), #B794F6);
  box-shadow: var(--shadow-fab);
}

.fab-secondary {
  background: linear-gradient(135deg, var(--secondary), #FFCBA4);
  box-shadow: 0 8rpx 24rpx rgba(255, 171, 118, 0.4);
}

.fab-accent {
  background: linear-gradient(135deg, var(--accent), #9AE3D6);
  box-shadow: 0 8rpx 24rpx rgba(125, 211, 192, 0.4);
}

.fab-icon-center {
  font-size: 56rpx;
  color: var(--white);
  font-weight: 300;
  line-height: 1;
}

/* 统一分隔线 */
.divider-line {
  height: 1rpx;
  background: var(--border);
}

/* 统一吸底操作区 */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-lg);
  background: var(--white);
  box-shadow: var(--shadow-bottom);
  display: flex;
  gap: var(--spacing-md);
  z-index: 100;
}

/* 主按钮 */
.btn-main {
  flex: 1;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-full);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-main-primary {
  background: linear-gradient(135deg, var(--primary), #B794F6);
  color: var(--white);
}

.btn-main-secondary {
  background: var(--white);
  border: 2rpx solid var(--primary);
  color: var(--primary);
}

/* 标签徽章统一 */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 12rpx;
  font-size: var(--text-tiny);
  border-radius: var(--radius-sm);
}

.badge-primary {
  background: linear-gradient(135deg, var(--primary), #B794F6);
  color: var(--white);
}

.badge-secondary {
  background: linear-gradient(135deg, var(--secondary), #FFCBA4);
  color: var(--white);
}

/* TabBar 占位 */
.tabbar-spacer {
  height: 120rpx;
}