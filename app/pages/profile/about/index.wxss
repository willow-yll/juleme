page {
  min-height: 100vh;
  background: var(--bg);
}

.page {
  min-height: 100vh;
  padding: 32rpx 24rpx;
  box-sizing: border-box;
}

.content-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  box-shadow: var(--shadow);
}

.hero-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, var(--primary), #B794F6);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 24rpx;
  line-height: 1;
}

.eyebrow {
  display: block;
  font-size: 22rpx;
  color: var(--primary);
  font-weight: 600;
  margin-bottom: 8rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 8rpx;
}

.version {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 24rpx;
}

.desc {
  display: block;
  font-size: 28rpx;
  line-height: 1.9;
  color: var(--text-light);
}

.info-section {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border);
}

.info-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 12rpx;
}

.info-text {
  display: block;
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--text-light);
}

.footer-note {
  margin-top: 32rpx;
  padding: 20rpx 24rpx;
  background: var(--bg);
  border-radius: 16rpx;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: var(--text-muted);
  text-align: center;
}