<!-- 个人中心 -->
<view class="page">
  <!-- 用户信息 -->
  <view class="user-section">
    <image class="user-bg" src="https://picsum.photos/400/200" mode="aspectFill" />
    <view class="user-info">
      <image class="user-avatar" src="https://picsum.photos/100" />
      <text class="user-name">我</text>
      <text class="user-bio">记录生活中的美好</text>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{stats.wishes}}</text>
      <text class="stat-label">愿望</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.museum}}</text>
      <text class="stat-label">回忆</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.moments}}</text>
      <text class="stat-label">瞬间</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.friends}}</text>
      <text class="stat-label">好友</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goToMuseum">
      <text class="menu-icon">🏛️</text>
      <text class="menu-text">回忆博物馆</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToCapsule">
      <text class="menu-icon">📅</text>
      <text class="menu-text">年度报告</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToMoments">
      <text class="menu-icon">🐱</text>
      <text class="menu-text">我的萌宠</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToAnniversary">
      <text class="menu-icon">💕</text>
      <text class="menu-text">我的纪念日</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 设置 -->
  <view class="menu-section">
    <view class="menu-item">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>