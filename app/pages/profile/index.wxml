<!-- 个人中心 -->
<view class="page">
  <!-- 用户信息 -->
  <view class="user-section">
    <view class="user-info">
      <view class="user-avatar" style="background: {{avatarBgColor}};">{{avatarText}}</view>
      <text class="user-name">{{userProfile.nickname || '我'}}</text>
      <text class="user-bio">圈子代码：{{currentCircle.code}}</text>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{stats.wishes}}</text>
      <text class="stat-label">活动</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.anniversaries}}</text>
      <text class="stat-label">纪念日</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.circles}}</text>
      <text class="stat-label">圈子</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.friends}}</text>
      <text class="stat-label">好友</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goToCapsule">
      <text class="menu-icon">📅</text>
      <text class="menu-text">年度报告</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToProfileSetup">
      <text class="menu-icon">📝</text>
      <text class="menu-text">填写资料</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToAnniversary">
      <text class="menu-icon">💕</text>
      <text class="menu-text">我的纪念日</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToCircles">
      <text class="menu-icon">👥</text>
      <text class="menu-text">我的圈子</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 设置 -->
  <view class="menu-section">
    <view class="menu-item">
      <text class="menu-icon">⚙️</text>
      <text class="menu-text">设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
</view>