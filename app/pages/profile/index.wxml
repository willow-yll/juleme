<!-- 个人中心 -->
<view class="page">
  <!-- 用户信息 -->
  <view class="user-section">
    <view class="user-info">
      <image wx:if="{{avatarUrl}}" class="user-avatar user-avatar-image" src="{{avatarUrl}}" mode="aspectFill" />
      <view wx:else class="user-avatar" style="background: {{avatarBgColor}};">{{avatarText}}</view>
      <text class="user-name">{{userProfile.nickname || '我'}}</text>
      <text class="user-bio">圈子代码：{{currentCircle ? currentCircle.code : '暂无'}}</text>
    </view>
  </view>


  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goToCapsule">
      <text class="menu-icon">📅</text>
      <text class="menu-text">年度报告</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToProfileSetup">
      <text class="menu-icon">📝</text>
      <text class="menu-text">填写资料</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToAnniversary">
      <text class="menu-icon">💕</text>
      <text class="menu-text">我的纪念日</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToCircles">
      <text class="menu-icon">👥</text>
      <text class="menu-text">我的圈子</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 设置 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="handleLeaveCircle" wx:if="{{currentCircle}}">
      <text class="menu-icon">🚪</text>
      <text class="menu-text">退出圈子</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item danger" bindtap="handleDeleteAccount">
      <text class="menu-icon">⛔</text>
      <text class="menu-text danger-text">注销账号</text>
      <text class="menu-arrow danger-text">›</text>
    </view>
  </view>
</view>