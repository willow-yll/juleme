/* 个人中心样式 */

.page {
  min-height: 100vh;
  background: var(--bg);
}

/* 用户信息 */
.user-section {
  margin: var(--spacing-lg);
  padding: 48rpx var(--spacing-lg);
  border-radius: var(--radius-lg);
  background: linear-gradient(135deg, #ffffff 0%, #f7f9fc 100%);
  box-shadow: var(--shadow);
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-circle);
  margin-bottom: var(--spacing-sm);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
}

.user-avatar-image {
  display: block;
  background: #F5F5F5;
}

.user-avatar-button,
.user-name-button {
  cursor: pointer;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 4rpx;
}

.user-bio {
  font-size: var(--text-small);
  color: var(--text-muted);
}

/* 菜单 */
.menu-section {
  background: #fff;
  margin: 0 var(--spacing-lg) var(--spacing-lg);
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx var(--spacing-lg);
  border-bottom: 1rpx solid var(--border);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: var(--spacing-md);
  line-height: 1;
}

.menu-text {
  flex: 1;
  font-size: var(--text-body);
  color: var(--text);
}

.menu-arrow {
  font-size: 32rpx;
  color: var(--text-muted);
}

.menu-item.danger {
  background: #FFF7F6;
}

.danger-text {
  color: #D4380D;
}
