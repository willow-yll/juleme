<!-- 个人资料设置页面 -->
<view class="page">
  <view class="header">
    <text class="title">完善个人资料</text>
    <text class="subtitle">完善后才能创建或加入圈子</text>
  </view>

  <view class="form">
    <view class="form-item">
      <text class="label">昵称</text>
      <input class="input" placeholder="请输入昵称" value="{{nickname}}" bindinput="onNicknameInput" maxlength="20" />
    </view>

    <view class="form-item">
      <text class="label">性别</text>
      <picker mode="selector" range="{{genderOptions}}" range-key="label" value="{{genderIndex < 0 ? 0 : genderIndex}}" bindchange="onGenderChange">
        <view class="picker-value">
          <text>{{genderIndex >= 0 ? genderOptions[genderIndex].label : '请选择'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">MBTI</text>
      <picker mode="selector" range="{{mbtiOptions}}" range-key="label" value="{{mbtiIndex < 0 ? 0 : mbtiIndex}}" bindchange="onMbtiChange">
        <view class="picker-value">
          <text>{{mbtiIndex >= 0 ? mbtiOptions[mbtiIndex].label : '请选择'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">星座</text>
      <picker mode="selector" range="{{constellationOptions}}" range-key="label" value="{{constellationIndex < 0 ? 0 : constellationIndex}}" bindchange="onConstellationChange">
        <view class="picker-value">
          <text>{{constellationIndex >= 0 ? constellationOptions[constellationIndex].label : '请选择'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <button class="save-btn" bindtap="handleSave">保存</button>
</view>