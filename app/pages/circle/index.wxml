<!-- 圈子入口页面 -->
<view class="page">
  <!-- 头部 -->
  <view class="header">
    <text class="header-title">我的圈子</text>
    <text class="header-subtitle">和朋友们一起完成愿望</text>
  </view>

  <!-- 圈子列表 -->
  <view class="circle-list">
    <block wx:for="{{circles}}" wx:key="id">
      <view class="circle-card" bindtap="enterCircle" data-id="{{item.id}}">
        <view class="circle-avatar" style="background: {{item.color}}">
          <text>{{item.name[0]}}</text>
        </view>
        <view class="circle-info">
          <text class="circle-name">{{item.name}}</text>
          <text class="circle-desc">{{item.memberCount}}位成员</text>
        </view>
        <view class="circle-role" wx:if="{{item.role === 'owner'}}">
          <text>圈主</text>
        </view>
        <view class="circle-arrow">›</view>
      </view>
    </block>

    <!-- 空状态 -->
    <view class="empty" wx:if="{{circles.length === 0}}">
      <text class="empty-icon">👥</text>
      <text class="empty-text">还没有加入任何圈子</text>
      <text class="empty-hint">点击右下角+创建或加入圈子</text>
    </view>
  </view>

  <!-- 待确认的加入申请 -->
  <view class="pending-section" wx:if="{{pendingRequests.length > 0}}">
    <text class="section-title">👀 待确认</text>
    <block wx:for="{{pendingRequests}}" wx:key="id">
      <view class="pending-card">
        <view class="pending-info">
          <text class="pending-name">{{item.name}}</text>
          <text class="pending-circle">申请加入：{{item.circleName}}</text>
        </view>
        <view class="pending-actions">
          <button class="btn-accept" bindtap="acceptRequest" data-id="{{item.id}}">同意</button>
          <button class="btn-reject" bindtap="rejectRequest" data-id="{{item.id}}">拒绝</button>
        </view>
      </view>
    </block>
  </view>

  <!-- 底部占位 -->
  <view class="tabbar-spacer"></view>

  <!-- 悬浮按钮 -->
  <view class="fab" bindtap="toggleFabMenu">
    <text class="fab-icon">+</text>
  </view>

  <!-- FAB 菜单 -->
  <view class="fab-menu" wx:if="{{showFabMenu}}">
    <view class="fab-overlay" bindtap="toggleFabMenu"></view>
    <view class="fab-options">
      <view class="fab-option" bindtap="goToCreateCircle">
        <text class="fab-option-icon">➕</text>
        <text class="fab-option-text">创建圈子</text>
      </view>
      <view class="fab-option" bindtap="goToJoinCircle">
        <text class="fab-option-icon">🔗</text>
        <text class="fab-option-text">加入圈子</text>
      </view>
    </view>
  </view>
</view>