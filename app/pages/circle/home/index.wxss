/* 圈子主页 */
.page {
  min-height: 100vh;
  background: var(--bg);
}

.header {
  padding: 48rpx var(--spacing-lg) 72rpx;
}

.circle-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.circle-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: var(--spacing-md);
}

.circle-name {
  font-size: 40rpx;
  color: #fff;
  font-weight: 700;
}

.member-count {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: var(--spacing-xs);
}

.top-actions {
  display: flex;
  gap: var(--spacing-md);
  padding: 0 var(--spacing-lg);
  margin-top: -32rpx;
}

.action-card {
  flex: 1;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-sm);
}

.action-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.action-icon {
  font-size: 44rpx;
  line-height: 1;
}

.action-text {
  font-size: 26rpx;
  color: var(--text);
}

.section-tabs {
  display: flex;
  gap: var(--spacing-md);
  padding: var(--spacing-lg);
}

.section-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  background: #fff;
  border-radius: var(--radius-lg);
  color: var(--text-light);
  font-size: var(--text-secondary);
  transition: all 0.3s ease;
}

.section-tab.active {
  background: linear-gradient(135deg, var(--primary), #B794F6);
  color: #fff;
  font-weight: 600;
}

.section {
  padding: 0 var(--spacing-lg) var(--spacing-lg);
}

.member-list,
.analysis-card {
  background: #fff;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
}

.member-card {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg);
  border-bottom: 1rpx solid var(--border);
}

.member-card:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-circle);
  margin-right: var(--spacing-md);
}

.member-info {
  flex: 1;
}

.member-name-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.member-name {
  font-size: 30rpx;
  color: var(--text);
  font-weight: 600;
}

.member-role {
  font-size: var(--text-tiny);
  background: linear-gradient(135deg, var(--secondary), #FFCBA4);
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-sm);
}

.member-meta {
  margin-top: var(--spacing-xs);
  display: flex;
  gap: var(--spacing-sm);
  flex-wrap: wrap;
  font-size: var(--text-tiny);
  color: var(--text-muted);
}

.analysis-card {
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
}

.analysis-title {
  display: block;
  font-size: var(--text-body);
  font-weight: 600;
  color: var(--text);
  margin-bottom: var(--spacing-md);
}

.analysis-bar-item {
  margin-bottom: var(--spacing-md);
}

.bar-label {
  display: flex;
  justify-content: space-between;
  font-size: var(--text-small);
  color: var(--text);
  margin-bottom: 8rpx;
}

.bar-track {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 8rpx;
}

.bar-fill.gender {
  background: linear-gradient(90deg, #FF6B6B, #FF9E7A);
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.report-tag {
  padding: 12rpx 16rpx;
  background: #f5f5f5;
  border-radius: var(--radius-md);
  font-size: var(--text-small);
  color: var(--text);
}

.empty-text {
  font-size: var(--text-small);
  color: var(--text-muted);
}

.tabbar-spacer {
  height: 120rpx;
}

/* 页面背景统一 */
.page {
  min-height: 100vh;
  background: var(--bg);
}