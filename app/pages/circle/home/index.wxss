/* 圈子主页 */
.page {
  min-height: 100vh;
  background: var(--bg);
}

.header {
  padding: 48rpx 32rpx 72rpx;
}

.circle-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.circle-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.circle-name {
  font-size: 40rpx;
  color: #fff;
  font-weight: 700;
}

.member-count {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 8rpx;
}

.top-actions {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx;
  margin-top: -32rpx;
}

.action-card {
  flex: 1;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: var(--shadow-sm);
}

.action-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 26rpx;
  color: var(--text);
}

.section-tabs {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
}

.section-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  background: #fff;
  border-radius: 24rpx;
  color: var(--text-light);
  font-size: 26rpx;
}

.section-tab.active {
  background: linear-gradient(135deg, var(--primary), #B794F6);
  color: #fff;
  font-weight: 600;
}

.section {
  padding: 0 24rpx 24rpx;
}

.member-list,
.analysis-card {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: var(--shadow-sm);
}

.member-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.member-card:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.member-info {
  flex: 1;
}

.member-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.member-name {
  font-size: 30rpx;
  color: var(--text);
  font-weight: 600;
}

.member-role {
  font-size: 22rpx;
  background: linear-gradient(135deg, var(--secondary), #FFCBA4);
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.member-meta {
  margin-top: 8rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  font-size: 22rpx;
  color: var(--text-muted);
}

.analysis-card {
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.analysis-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

.analysis-bar-item {
  margin-bottom: 16rpx;
}

.bar-label {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: var(--text);
  margin-bottom: 8rpx;
}

.bar-track {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 8rpx;
}

.bar-fill.gender {
  background: linear-gradient(90deg, #FF6B6B, #FF9E7A);
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.report-tag {
  padding: 12rpx 16rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: var(--text);
}

.empty-text {
  font-size: 24rpx;
  color: var(--text-muted);
}

.tabbar-spacer {
  height: 120rpx;
}