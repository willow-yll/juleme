<!-- 圈子主页 -->
<view class="page page-state" wx:if="{{loading}}">
  <text class="state-text">加载中...</text>
</view>

<view class="page page-state" wx:elif="{{pageError}}">
  <text class="state-text">{{pageError}}</text>
</view>

<view class="page page-state" wx:elif="{{!circle}}">
  <text class="state-text">正在为你跳转...</text>
</view>

<view class="page" wx:else>
  <view class="header" style="background: linear-gradient(135deg, {{circle.color}} 0%, {{circle.color}}CC 100%)">
    <view class="circle-info">
      <view class="circle-avatar">{{circle.name[0]}}</view>
      <text class="circle-name">{{circle.name}}</text>
      <text class="member-count">{{members.length}} 位圈友</text>
      <text class="member-count">圈子代码：{{circle.code}}</text>
    </view>
  </view>

  <view class="top-actions">
    <view class="action-card" bindtap="goToCircleList">
      <view class="action-icon-wrap">
        <text class="action-icon">👥</text>
      </view>
      <text class="action-text">切换圈子</text>
    </view>
    <view class="action-card" wx:if="{{isOwner}}" bindtap="goToRenameCircle">
      <view class="action-icon-wrap">
        <text class="action-icon">✏️</text>
      </view>
      <text class="action-text">修改圈名</text>
    </view>
    <view class="action-card" bindtap="goToCreate">
      <view class="action-icon-wrap">
        <text class="action-icon">➕</text>
      </view>
      <text class="action-text">去发布</text>
    </view>
  </view>

  <view class="section-tabs">
    <view class="section-tab {{activeSection === 'members' ? 'active' : ''}}" bindtap="switchSection" data-section="members">全部成员</view>
    <view class="section-tab {{activeSection === 'analysis' ? 'active' : ''}}" bindtap="switchSection" data-section="analysis">圈友报告</view>
  </view>

  <view class="section" wx:if="{{activeSection === 'members'}}">
    <view class="pending-review-card" wx:if="{{isOwner && pendingRequests.length > 0}}">
      <view class="pending-review-header">
        <text class="pending-review-title">待处理加入申请</text>
        <text class="pending-review-count">{{pendingRequests.length}} 条</text>
      </view>
      <block wx:for="{{pendingRequests}}" wx:key="id">
        <view class="pending-review-item">
          <view class="pending-review-info">
            <text class="pending-review-name">{{item.userName}}</text>
            <text class="pending-review-desc">申请加入当前圈子</text>
          </view>
          <view class="pending-review-actions">
            <button class="pending-btn pending-btn-accept" bindtap="acceptRequest" data-id="{{item.id}}">同意</button>
            <button class="pending-btn pending-btn-reject" bindtap="rejectRequest" data-id="{{item.id}}">拒绝</button>
          </view>
        </view>
      </block>
    </view>

    <view class="member-list">
      <view class="member-card member-action-card" bindtap="handleLeaveCircle">
        <view class="member-avatar member-action-avatar">
          <text>🚪</text>
        </view>
        <view class="member-info">
          <view class="member-name-row">
            <text class="member-name">退出当前圈子</text>
          </view>
          <view class="member-meta">
            <text>退出后你在该圈的活动报名会被取消</text>
          </view>
        </view>
      </view>
      <view class="member-card" wx:for="{{members}}" wx:key="id">
        <image class="member-avatar" src="{{item.avatar || defaultAvatar}}" mode="aspectFill" />
        <view class="member-info">
          <view class="member-name-row">
            <text class="member-name">{{item.name}}</text>
            <text class="member-role" wx:if="{{item.role === 'owner'}}">圈主</text>
          </view>
          <view class="member-meta">
            <text wx:if="{{item.gender}}">{{item.gender}}</text>
            <text wx:if="{{item.mbti}}">{{item.mbti}}</text>
            <text wx:if="{{item.constellation}}">{{item.constellation}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="section" wx:if="{{activeSection === 'analysis'}}">
    <!-- 统计数据 -->
    <view class="stats-summary">
      <view class="stat-item-wrap">
        <text class="stat-num-large">{{stats.totalGatherings}}</text>
        <text class="stat-label-small">聚会</text>
      </view>
      <view class="stat-item-wrap">
        <text class="stat-num-large">{{stats.totalDishes}}</text>
        <text class="stat-label-small">饭饭</text>
      </view>
      <view class="stat-item-wrap">
        <text class="stat-num-large">{{stats.totalCities}}</text>
        <text class="stat-label-small">足迹</text>
      </view>
    </view>

    <!-- 排行榜 -->
    <view class="leaderboard-section">
      <text class="section-subtitle">🏆 荣誉榜</text>
      <view class="leaderboard-grid">
        <!-- 捧场王 -->
        <view class="leaderboard-card king-party">
          <view class="king-icon">🎉</view>
          <text class="king-title">捧场王</text>
          <text class="king-desc">每次都有你</text>
          <view class="king-winner" wx:if="{{leaderboard.partyKing}}">
            <image class="king-avatar" src="{{leaderboard.partyKing.avatar || defaultAvatar}}" />
            <text class="king-name">{{leaderboard.partyKing.name}}</text>
            <text class="king-count">{{leaderboard.partyKing.eventsJoined}}次</text>
          </view>
          <view class="king-empty" wx:else>
            <text>虚位以待</text>
          </view>
        </view>

        <!-- 干饭王 -->
        <view class="leaderboard-card king-food">
          <view class="king-icon">🍽️</view>
          <text class="king-title">干饭王</text>
          <text class="king-desc">吃饭必有你</text>
          <view class="king-winner" wx:if="{{leaderboard.foodKing}}">
            <image class="king-avatar" src="{{leaderboard.foodKing.avatar || defaultAvatar}}" />
            <text class="king-name">{{leaderboard.foodKing.name}}</text>
            <text class="king-count">{{leaderboard.foodKing.diningCount}}次</text>
          </view>
          <view class="king-empty" wx:else>
            <text>虚位以待</text>
          </view>
        </view>

        <!-- 局头 -->
        <view class="leaderboard-card king-organizer">
          <view class="king-icon">🎯</view>
          <text class="king-title">局头子</text>
          <text class="king-desc">发起活动最多</text>
          <view class="king-winner" wx:if="{{leaderboard.organizerKing}}">
            <image class="king-avatar" src="{{leaderboard.organizerKing.avatar || defaultAvatar}}" />
            <text class="king-name">{{leaderboard.organizerKing.name}}</text>
            <text class="king-count">{{leaderboard.organizerKing.eventsCreated}}次</text>
          </view>
          <view class="king-empty" wx:else>
            <text>虚位以待</text>
          </view>
        </view>
      </view>
    </view>

    <view class="analysis-card ai-card">
      <view class="ai-header">
        <view>
          <text class="analysis-title">AI 解读</text>
          <text class="ai-description">关于这个圈子的一些的小观察</text>
        </view>
        <view class="ai-badge">轻量画像</view>
      </view>
      <button class="btn btn-primary ai-button" loading="{{llmLoading}}" bindtap="handleGenerateInterpretation">
        {{llmLoading ? '解读生成中...' : '生成圈子画像'}}
      </button>
      <view class="ai-result" wx:if="{{llmInterpretation}}">
        <view class="ai-result-header">
          <text class="ai-result-title">圈子气质小结</text>
        </view>
        <view class="ai-result-content">
          <block wx:for="{{llmInterpretationBlocks}}" wx:key="index">
            <view wx:if="{{item.type === 'heading1'}}" class="ai-markdown-heading ai-markdown-heading-1">
              <block wx:for="{{item.segments}}" wx:for-item="segment" wx:key="index">
                <text class="ai-result-segment {{segment.bold ? 'ai-result-bold' : ''}}">{{segment.text}}</text>
              </block>
            </view>
            <view wx:elif="{{item.type === 'heading2'}}" class="ai-markdown-heading ai-markdown-heading-2">
              <block wx:for="{{item.segments}}" wx:for-item="segment" wx:key="index">
                <text class="ai-result-segment {{segment.bold ? 'ai-result-bold' : ''}}">{{segment.text}}</text>
              </block>
            </view>
            <view wx:elif="{{item.type === 'list'}}" class="ai-markdown-list">
              <view class="ai-markdown-list-item" wx:for="{{item.items}}" wx:for-item="listItem" wx:key="index">
                <view class="ai-markdown-list-dot"></view>
                <view class="ai-markdown-list-text">
                  <block wx:for="{{listItem.segments}}" wx:for-item="segment" wx:key="index">
                    <text class="ai-result-segment {{segment.bold ? 'ai-result-bold' : ''}}">{{segment.text}}</text>
                  </block>
                </view>
              </view>
            </view>
            <view wx:else class="ai-markdown-paragraph">
              <block wx:for="{{item.segments}}" wx:for-item="segment" wx:key="index">
                <text class="ai-result-segment {{segment.bold ? 'ai-result-bold' : ''}}">{{segment.text}}</text>
              </block>
            </view>
          </block>
        </view>
      </view>
      <view class="ai-error" wx:if="{{llmError}}">
        <text class="ai-error-text">{{llmError}}</text>
      </view>
    </view>

    <!-- 性别分布 -->
    <view class="analysis-card">
      <text class="analysis-title">性别分布</text>
      <view class="analysis-bar-item" wx:for="{{analysis.gender}}" wx:key="name">
        <view class="bar-label">
          <text>{{item.name}}</text>
          <text>{{item.count}}人 · {{item.percentage}}%</text>
        </view>
        <view class="bar-track">
          <view class="bar-fill gender" style="width: {{item.percentage}}%;"></view>
        </view>
      </view>
    </view>

    <view class="analysis-card">
      <text class="analysis-title">MBTI 分布</text>
      <view class="tag-list" wx:if="{{analysis.mbti.length}}">
        <view class="report-tag" wx:for="{{analysis.mbti}}" wx:key="name">{{item.name}} · {{item.count}}人</view>
      </view>
      <text class="empty-text" wx:else>暂无 MBTI 数据</text>
    </view>

    <view class="analysis-card">
      <text class="analysis-title">星座分布</text>
      <view class="tag-list" wx:if="{{analysis.constellation.length}}">
        <view class="report-tag" wx:for="{{analysis.constellation}}" wx:key="name">{{item.name}} · {{item.count}}人</view>
      </view>
      <text class="empty-text" wx:else>暂无星座数据</text>
    </view>
  </view>

  <view class="tabbar-spacer"></view>
</view>