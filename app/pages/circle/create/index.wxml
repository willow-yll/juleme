<!-- 创建圈子 -->
<view class="page">
  <view class="form">
    <view class="form-group">
      <text class="label">圈子名称</text>
      <input class="input" placeholder="给你的圈子起个名字" bindinput="onNameInput" value="{{name}}" />
    </view>

    <view class="form-group">
      <text class="label">圈子简介（可选）</text>
      <textarea class="textarea" placeholder="介绍一下这个圈子..." bindinput="onDescInput" value="{{description}}" />
    </view>

    <view class="form-group">
      <text class="label">选择颜色</text>
      <view class="color-list">
        <view
          class="color-item {{color === item ? 'active' : ''}}"
          wx:for="{{colors}}"
          wx:key="index"
          style="background: {{item}}"
          bindtap="selectColor"
          data-color="{{item}}"
        ></view>
      </view>
    </view>

    <view class="form-group">
      <text class="label">圈子号码</text>
      <view class="code-display">
        <text class="code">{{code}}</text>
        <text class="code-hint">分享给朋友，让他们输入号码加入</text>
      </view>
    </view>
  </view>

  <view class="submit-btn">
    <button class="btn btn-primary btn-block" bindtap="handleCreate">创建圈子</button>
  </view>
</view>