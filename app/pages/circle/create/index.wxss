/* 创建圈子样式 */

.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 140rpx;
}

.form {
  padding: 32rpx 24rpx;
}

.form-group {
  margin-bottom: 40rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text);
  display: block;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 0 24rpx; /* 去掉上下padding，避免挤压 */
  font-size: 28rpx;
  box-sizing: border-box;
  /* 核心：固定高度 + 行高匹配，实现单行垂直居中 */
  height: 80rpx; /* 自定义高度，根据需求调整 */
  line-height: 80rpx; /* 和height一致 */
}

.textarea {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  min-height: 160rpx;
  box-sizing: border-box;
}

/* 颜色选择 */
.color-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.color-item {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
}

.color-item.active {
  border-color: var(--text);
}

/* 圈子号码 */
.code-display {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  text-align: center;
}

.code {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--primary);
  letter-spacing: 8rpx;
  display: block;
}

.code-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
  display: block;
}

/* 提交按钮 */
.submit-btn {
  position: fixed;
  z-index: 100;
  /* 核心：水平居中 + 宽度可控 */
  left: 50%;
  transform: translateX(-50%);
  /* 基础样式（精简后） */
  width: 90vw; /* 建议用90vw，避免贴边，居中更美观 */
  margin: 0;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-block {
  width: 100%;
  padding: 24rpx 0;
  font-size: 32rpx;
}