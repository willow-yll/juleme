/* 修改圈名样式 */

.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 140rpx;
}

.form {
  padding: 32rpx 24rpx;
}

.form-group {
  margin-bottom: 40rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text);
  display: block;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  height: 96rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 0 24rpx;
  line-height: 96rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.btn-block {
  width: 100%;
  padding: 24rpx 0;
  font-size: 32rpx;
}
