/* 愿望详情样式 */

.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 120rpx;
}

/* 顶部图片 */
.hero-image {
  height: 400rpx;
  background: linear-gradient(135deg, var(--primary), #B794F6);
  position: relative;
}

.hero-overlay {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
}

.category-badge {
  display: inline-flex;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

/* 内容区 */
.content {
  margin-top: -40rpx;
  position: relative;
  z-index: 10;
  padding: 24rpx;
}

.wish-info {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.wish-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
  display: block;
  margin-bottom: 12rpx;
}

.wish-desc {
  font-size: 28rpx;
  color: var(--text-light);
  line-height: 1.8;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.section-title {
  font-size: 26rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 16rpx;
}

/* 发起人 */
.creator-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.creator-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

/* 日期 */
.date-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.date-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

.date-countdown {
  font-size: 28rpx;
  color: var(--secondary);
  font-weight: 500;
}

/* 进度 */
.progress-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background: var(--bg);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--secondary));
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}

/* 认领列表 */
.claim-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.claim-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx;
  background: var(--bg);
  border-radius: 12rpx;
}

.claimer-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.avatar-sm {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.claimer-name {
  font-size: 28rpx;
  color: var(--text);
}

.want-go {
  font-size: 24rpx;
  color: #4CAF50;
}

.empty-claim {
  text-align: center;
  padding: 24rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}

/* 操作按钮 */
.actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  display: flex;
  gap: 16rpx;
  z-index: 100;
}

.actions .btn {
  flex: 1;
}

.btn-cancel {
  background: #fff !important;
  color: #FF6B6B !important;
  border: 2rpx solid #FF6B6B !important;
}

/* 加载 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}