/* 活动页面样式 - 时间轴形式 */

.page {
  min-height: 100vh;
  background: var(--bg);
}

/* 筛选标签 */
.tabs {
  display: flex;
  background: #fff;
  padding: var(--spacing-md) var(--spacing-lg);
  gap: var(--spacing-md);
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: var(--shadow-sm);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: var(--text-secondary);
  color: var(--text-light);
  border-radius: var(--radius-lg);
  transition: all 0.3s ease;
}

.tab.active {
  background: linear-gradient(135deg, var(--primary), #B794F6);
  color: #fff;
  font-weight: 600;
}

/* 时间轴 */
.timeline {
  height: calc(100vh - 100rpx - 120rpx);
}

.timeline-container {
  padding: var(--spacing-lg);
  padding-left: 48rpx;
}

.timeline-item {
  position: relative;
  padding-bottom: var(--spacing-lg);
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-item:last-child .timeline-line {
  display: none;
}

/* 时间轴线 - 修正对齐 */
.timeline-line {
  position: absolute;
  left: -25rpx;
  top: 16rpx;
  bottom: -32rpx;
  width: 2rpx;
  background: #e0e0e0;
}

.timeline-item.past .timeline-line {
  background: #ccc;
}

/* 时间轴点 - 修正对齐 */
.timeline-dot {
  position: absolute;
  left: -33rpx;
  top: 10rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: var(--radius-circle);
  background: var(--primary);
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 2rpx var(--primary);
}

.timeline-dot.past {
  background: #ccc;
  box-shadow: 0 0 0 2rpx #ccc;
}

.timeline-dot.today {
  background: #FF6B6B;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 107, 0.3);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { box-shadow: 0 0 0 4rpx rgba(255, 107, 107, 0.3); }
  50% { box-shadow: 0 0 0 8rpx rgba(255, 107, 107, 0.1); }
  100% { box-shadow: 0 0 0 4rpx rgba(255, 107, 107, 0.3); }
}

/* 日期标签 */
.timeline-date {
  margin-bottom: var(--spacing-sm);
  padding-left: 8rpx;
}

.timeline-date text {
  font-size: var(--text-small);
  color: var(--primary);
  font-weight: 500;
}

.timeline-item.past .timeline-date text {
  color: var(--text-muted);
}

.timeline-item.today .timeline-date text {
  color: #FF6B6B;
}

/* 活动卡片 */
.wish-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow);
}

.timeline-item.past .wish-card {
  opacity: 0.7;
}

/* 分类标签 */
.wish-category {
  display: inline-flex;
  align-items: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-xs) var(--spacing-md);
  border-radius: 20rpx;
  margin-bottom: var(--spacing-md);
}

.tag-restaurant { background: #FFF3E0; }
.tag-travel { background: #E3F2FD; }
.tag-sport { background: #E8F5E9; }
.tag-entertainment { background: #FCE4EC; }
.tag-other { background: #F3E5F5; }

.category-icon {
  font-size: var(--text-small);
}

.category-text {
  font-size: var(--text-tiny);
  font-weight: 500;
}

.tag-restaurant .category-text { color: #FF9800; }
.tag-travel .category-text { color: #2196F3; }
.tag-sport .category-text { color: #4CAF50; }
.tag-entertainment .category-text { color: #E91E63; }
.tag-other .category-text { color: #9C27B0; }

/* 活动内容 */
.wish-content {
  margin-bottom: var(--spacing-md);
}

.wish-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  display: block;
  margin-bottom: var(--spacing-xs);
}

.wish-desc {
  font-size: var(--text-secondary);
  color: var(--text-light);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 发起人 */
.wish-claim {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) 0;
  border-top: 1rpx solid var(--border);
  border-bottom: 1rpx solid var(--border);
}

.creator {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.avatar-sm {
  width: 48rpx;
  height: 48rpx;
  border-radius: var(--radius-circle);
}

.creator-name {
  font-size: var(--text-small);
  color: var(--text-light);
}

.claimers {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

.claim-count {
  font-size: var(--text-small);
  color: var(--primary);
  font-weight: 500;
}

/* 操作按钮 - 统一高度与居中 */
.wish-actions {
  display: flex;
  gap: var(--spacing-md);
  margin-top: var(--spacing-md);
}

.action-btn-primary,
.action-btn-secondary,
.action-btn-cancel {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  border-radius: var(--radius-lg);
  font-size: var(--text-secondary);
  font-weight: 500;
  min-height: 72rpx;
  line-height: 1;
}

.action-btn-primary {
  background: linear-gradient(135deg, var(--primary), #B794F6);
  color: #fff;
}

.action-btn-secondary {
  background: var(--bg);
  color: var(--text-light);
}

.action-btn-cancel {
  background: #fff;
  color: #FF6B6B;
  border: 2rpx solid #FF6B6B;
}

.action-btn-primary.disabled {
  background: #ccc;
  color: #fff;
}

/* 底部占位 */
.tabbar-spacer {
  height: 120rpx;
}

/* 悬浮按钮 - 统一使用全局样式 */
.fab {
  position: fixed;
  bottom: 160rpx;
  right: var(--spacing-lg);
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-circle);
  background: linear-gradient(135deg, var(--primary), #B794F6);
  box-shadow: var(--shadow-fab);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.fab:active {
  transform: scale(0.95);
}

.fab-icon {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
  line-height: 1;
}

/* 空状态 - 统一使用全局样式 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: var(--spacing-md);
  line-height: 1;
}

.empty-text {
  font-size: var(--text-body);
  color: var(--text-muted);
}

.btn {
  padding: 20rpx 48rpx;
  border-radius: var(--radius-full);
  font-size: var(--text-body);
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary), #B794F6);
  color: #fff;
}

.mt-20 {
  margin-top: var(--spacing-md);
}

/* 按钮文字居中 */
.btn-text {
  line-height: 1;
}

/* 空状态使用全局类 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon-center {
  font-size: 120rpx;
  margin-bottom: var(--spacing-md);
  line-height: 1;
}

.empty-text-center {
  font-size: var(--text-body);
  color: var(--text-muted);
}