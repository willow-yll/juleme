/* 年度报告样式 */

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  color: #fff;
}

/* 封面 */
.cover {
  height: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.cover-year {
  font-size: 160rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #9B7DED, #FFAB76);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.cover-title {
  font-size: 56rpx;
  font-weight: 700;
  margin-top: -20rpx;
}

.cover-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 12rpx;
}

/* 区块 */
.section {
  padding: 40rpx 32rpx;
}

.section-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 24rpx;
}

/* 词云 */
.words {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
}

.word {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.1);
}

.word-lg {
  font-size: 36rpx;
  font-weight: 600;
  background: linear-gradient(135deg, rgba(155, 125, 237, 0.3), rgba(255, 171, 118, 0.3));
}

.word-md {
  font-size: 28rpx;
  background: rgba(125, 211, 192, 0.2);
}

.word-sm {
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.1);
}

/* 勤奋榜 */
.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
}

.rank-num {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #FFD700, #FFA500);
  border-radius: 50%;
  margin-right: 16rpx;
}

.ranking-item:nth-child(2) .rank-num {
  background: linear-gradient(135deg, #C0C0C0, #A0A0A0);
}

.ranking-item:nth-child(3) .rank-num {
  background: linear-gradient(135deg, #CD7F32, #B87333);
}

.rank-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.rank-name {
  flex: 1;
  font-size: 28rpx;
}

.rank-badge {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.rank-count {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 陪伴值 */
.companion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.companion-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
}

.companion-avatars {
  display: flex;
  margin-bottom: 12rpx;
}

.companion-avatars .avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #1a1a2e;
}

.companion-avatars .avatar:last-child {
  margin-left: -20rpx;
}

.companion-names {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.companion-value {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 随机回忆 */
.memory-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background: linear-gradient(135deg, rgba(155, 125, 237, 0.3), rgba(255, 171, 118, 0.3));
  border-radius: 24rpx;
}

.memory-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.memory-title {
  font-size: 40rpx;
  font-weight: 700;
  margin: 12rpx 0;
}

.memory-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 底部 */
.footer {
  padding: 60rpx 32rpx;
  text-align: center;
}

.footer-text {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}

.footer-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
  margin: 12rpx 0 32rpx;
}

.footer .btn {
  display: inline-block;
  padding: 20rpx 60rpx;
}