/* 首页样式 - 动态墙 */

.page {
  min-height: 100vh;
  background: var(--bg);
}

/* 顶部氛围区 */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-gradient {
  background: linear-gradient(135deg, #9B7DED 0%, #B794F6 50%, #FFAB76 100%);
  padding: 40rpx 32rpx 60rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.weather-icon {
  font-size: 80rpx;
}

.date-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.date-week {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 600;
}

.date-full {
  font-size: 48rpx;
  color: #fff;
  font-weight: 700;
}

/* 动态容器 */
.feed-container {
  padding: 20rpx 24rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 10;
}

.feed-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 动态卡片 */
.feed-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(155, 125, 237, 0.1);
  opacity: 0;
}

/* 用户信息 */
.feed-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.feed-time {
  font-size: 22rpx;
  color: var(--text-muted);
}

.type-tag {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.tag-wish { background: #FFF3E0; }
.tag-anniversary { background: #FCE4EC; }

/* 内容 */
.feed-content {
  margin-bottom: 16rpx;
}

.feed-action {
  font-size: 26rpx;
  color: var(--text-light);
  display: block;
  margin-bottom: 8rpx;
}

.feed-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
}

/* 图片 */
.feed-image {
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.feed-image image {
  width: 100%;
  height: 300rpx;
  display: block;
}

/* 互动按钮 */
.feed-actions {
  display: flex;
  gap: 32rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.action-icon {
  font-size: 32rpx;
}

.action-count {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 弹幕评论 */
.barrage-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: var(--bg);
  border-radius: 12rpx;
}

.barrage-item {
  font-size: 24rpx;
  color: var(--primary);
  padding: 6rpx 16rpx;
  background: rgba(155, 125, 237, 0.1);
  border-radius: 20rpx;
}

/* 底部占位 */
.tabbar-spacer {
  height: 120rpx;
}

/* 悬浮按钮 */
.fab {
  position: fixed;
  bottom: 160rpx;
  right: 32rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), #B794F6);
  box-shadow: 0 8rpx 24rpx rgba(155, 125, 237, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: transform 0.3s ease;
}

.fab:active {
  transform: scale(0.95);
}

.fab-icon {
  font-size: 56rpx;
  color: #fff;
  font-weight: 300;
}