/* 创建页面样式 */

.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 140rpx;
}

/* 类型选择 */
.type-selector {
  display: flex;
  background: #fff;
  padding: 24rpx;
  gap: 16rpx;
}

.type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  border-radius: 16rpx;
  background: var(--bg);
  transition: all 0.3s ease;
}

.type-item.active {
  background: linear-gradient(135deg, var(--primary), #B794F6);
}

.type-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.type-name {
  font-size: 24rpx;
  color: var(--text);
}

.type-item.active .type-name {
  color: #fff;
}

/* 表单 */
.form {
  padding: 24rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.label {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text);
  display: block;
  margin-bottom: 12rpx;
}

.input {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-title {
  font-size: 32rpx;
  font-weight: 500;
  padding: 28rpx 24rpx;
}

.textarea {
  width: 100%;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  min-height: 160rpx;
  box-sizing: border-box;
}

/* 分类选择 */
.category-list {
  display: flex;
  gap: 16rpx;
}

.category-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.category-item.active {
  border-color: var(--primary);
  background: rgba(155, 125, 237, 0.05);
}

.category-item text:first-child {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.category-item text:last-child {
  font-size: 24rpx;
  color: var(--text-light);
}

.category-item.active text:last-child {
  color: var(--primary);
}

/* 日期选择器 */
.picker {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.placeholder {
  color: var(--text-muted);
}

/* 认领人数 */
.claim-slider {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
}

.claim-slider slider {
  flex: 1;
}

.slider-value {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 600;
  margin-left: 16rpx;
}

/* 纪念日类型切换 */
.type-switch {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.switch-item {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--text-light);
}

.switch-item.active {
  background: var(--primary);
  color: #fff;
}

/* 图片上传 */
.image-uploader {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 300rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx dashed var(--border);
}

.upload-icon {
  font-size: 64rpx;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* 提交按钮 */
.submit-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.btn-block {
  width: 100%;
  padding: 24rpx 0;
  font-size: 32rpx;
}