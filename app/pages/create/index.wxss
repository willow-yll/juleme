/* 创建页面样式 */

.page {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 140rpx;
}

/* 类型选择 */
.type-selector {
  display: flex;
  background: #fff;
  padding: var(--spacing-lg);
  gap: var(--spacing-md);
}

.type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-md);
  border-radius: var(--radius-md);
  background: var(--bg);
  transition: all 0.3s ease;
}

.type-item.active {
  background: linear-gradient(135deg, var(--primary), #B794F6);
}

.type-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-xs);
}

.type-icon {
  font-size: 48rpx;
  line-height: 1;
}

.type-name {
  font-size: var(--text-small);
  color: var(--text);
}

.type-item.active .type-name {
  color: #fff;
}

/* 表单 */
.form {
  padding: var(--spacing-lg);
}

.form-group {
  margin-bottom: var(--spacing-xl);
}

/* 表单卡片化 */
.form-group-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
}

.label {
  font-size: var(--text-secondary);
  font-weight: 500;
  color: var(--text);
  display: block;
  margin-bottom: var(--spacing-sm);
}

.input {
  width: 100%;
  background: #fff;
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  font-size: var(--text-body);
  box-sizing: border-box;
}

.input-title {
  font-size: 32rpx;
  font-weight: 500;
  padding: 28rpx var(--spacing-lg);
}

.textarea {
  width: 100%;
  background: #fff;
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  font-size: var(--text-body);
  min-height: 160rpx;
  box-sizing: border-box;
}

/* 分类选择 */
.category-list {
  display: flex;
  gap: var(--spacing-sm);
}

.category-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-md);
  background: #fff;
  border-radius: var(--radius-md);
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.category-item.active {
  border-color: var(--primary);
  background: rgba(155, 125, 237, 0.05);
}

.category-item-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-item-name {
  font-size: var(--text-small);
  color: var(--text-light);
}

.category-item.active .category-item-name {
  color: var(--primary);
}

/* 分类选择 - 兼容旧选择器 */
.category-item text:first-child {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.category-item text:last-child {
  font-size: var(--text-small);
  color: var(--text-light);
}

.category-item.active text:last-child {
  color: var(--primary);
}

/* 日期选择器 */
.picker {
  background: #fff;
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  font-size: var(--text-body);
}

.picker.disabled {
  opacity: 0.5;
}

.date-undecided-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: var(--spacing-md);
  background: #fff;
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-lg);
}

.undecided-label {
  font-size: var(--text-secondary);
  color: var(--text-light);
}

.placeholder {
  color: var(--text-muted);
}

/* 认领人数 */
.claim-slider {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-lg);
}

.claim-slider slider {
  flex: 1;
}

.slider-value {
  font-size: var(--text-body);
  color: var(--primary);
  font-weight: 600;
  margin-left: var(--spacing-md);
}

/* 纪念日类型切换 */
.type-switch {
  display: flex;
  background: #fff;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.switch-item {
  flex: 1;
  text-align: center;
  padding: var(--spacing-lg);
  font-size: var(--text-body);
  color: var(--text-light);
}

.switch-item.active {
  background: var(--primary);
  color: #fff;
}

/* 图片上传 */
.image-uploader {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 300rpx;
  background: #fff;
  border-radius: var(--radius-md);
  border: 2rpx dashed var(--border);
}

.upload-icon {
  font-size: 64rpx;
  margin-bottom: var(--spacing-sm);
  line-height: 1;
}

.upload-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-text {
  font-size: var(--text-secondary);
  color: var(--text-muted);
}

/* 提交按钮 */
.submit-btn {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-lg);
  background: #fff;
  box-shadow: var(--shadow-bottom);
  z-index: 100;
}

.btn-block {
  width: 100%;
  padding: var(--spacing-lg) 0;
  font-size: 32rpx;
}